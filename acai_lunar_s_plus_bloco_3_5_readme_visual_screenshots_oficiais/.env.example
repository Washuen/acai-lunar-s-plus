# Server
NODE_ENV=development
PORT=3333

# PostgreSQL connection string
# Local example:
DATABASE_URL="postgresql://postgres:123456@localhost:5433/acai_lunar?schema=public"

# Auth
JWT_SECRET="change_this_secret_before_production"
JWT_EXPIRES_IN="7d"

# Smoke test optional variables
SMOKE_BASE_URL="http://localhost:3333"
SMOKE_OWNER_EMAIL="owner@acailunar.dev"
SMOKE_OWNER_PASSWORD="123456"
SMOKE_CUSTOMER_EMAIL="cliente@acailunar.dev"
SMOKE_CUSTOMER_PASSWORD="123456"
