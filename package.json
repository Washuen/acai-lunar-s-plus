{
  "name": "acai-lunar-s-plus",
  "version": "1.0.0",
  "description": "Açaí Lunar S+ Super — plataforma fullstack premium de delivery de açaí com área do cliente, admin, checkout real, PostgreSQL, Prisma, JWT, testes e documentação profissional.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "check": "node --check src/server.js && node --check public/app.js",
    "check:all": "node scripts/check-project.js",
    "test:smoke": "node scripts/smoke-test.js",
    "test:manual": "node scripts/print-manual-checklist.js",
    "github:preflight": "node scripts/github-preflight.js",
    "deploy:preflight": "node scripts/render-preflight.js",
    "deploy:postcheck": "node scripts/render-postdeploy-check.js",
    "production:check": "node scripts/production-check.js",
    "production:fullcheck": "node scripts/production-fullcheck.js"
  },
  "keywords": [
    "nodejs",
    "express",
    "postgresql",
    "prisma",
    "jwt-authentication",
    "delivery-platform",
    "restaurant-system",
    "admin-dashboard",
    "customer-area",
    "fullstack",
    "portfolio",
    "render-deploy",
    "acai"
  ],
  "author": "Luiz Silva",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SEU_USUARIO/acai-lunar-s-plus.git"
  },
  "bugs": {
    "url": "https://github.com/SEU_USUARIO/acai-lunar-s-plus/issues"
  },
  "homepage": "https://github.com/SEU_USUARIO/acai-lunar-s-plus#readme"
}